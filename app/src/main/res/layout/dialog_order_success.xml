<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingVertical="16dp">

    <!-- Main card (animated in code: fade + slide up) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dialogCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="28dp">

            <!-- Lottie success animation (requires Lottie dep).
                 Falls back gracefully if not present. -->
            <!-- If you have Lottie add this dep:
                 implementation 'com.airbnb.android:lottie:6.1.0'
                 and put success.json in res/raw/ -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieSuccess"
                android:layout_width="130dp"
                android:layout_height="130dp"
                app:lottie_rawRes="@raw/success"
                app:lottie_autoPlay="false"
                app:lottie_loop="false"/>

            <!-- Fallback icon shown if Lottie not available -->
            <!--
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/MainColor"/>
            -->

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Order Placed!"
                android:textSize="22sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/poppins_bold"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Thank you for your purchase!"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- Order details row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Order ID"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvDialogOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order #XXXXXXXX"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Paid"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvDialogTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="16sp"
                    android:textColor="@color/MainColor"
                    android:fontFamily="@font/poppins_bold"/>
            </LinearLayout>

            <!-- Status badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Status: Pending"
                android:background="@drawable/bg_stock_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textSize="12sp"
                android:textColor="#1B7B3A"
                android:fontFamily="@font/poppins_semibold"/>

            <!-- Done button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogDone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Done"
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:fontFamily="@font/poppins_semibold"
                app:backgroundTint="@color/MainColor"
                app:cornerRadius="14dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>