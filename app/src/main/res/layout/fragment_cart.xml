<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".Views.CartFragment">

    <!-- ─────────────────────────────────────────
         Scrollable Cart List
    ───────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="180dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Cart"
                    android:textSize="22sp"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/poppins_bold"/>

                <!-- Item count badge -->
                <TextView
                    android:id="@+id/tvItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Item"
                    android:background="@drawable/bg_category_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/MainColor"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:fontFamily="@font/poppins_semibold"/>

            </LinearLayout>

            <!-- ── RecyclerView for Cart Items ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCartItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                tools:itemCount="3"
                tools:listitem="@layout/item_cart"/>

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- ── Promo Code Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_quantity_selector"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_cart"
                        android:layout_marginEnd="8dp"
                        app:tint="?attr/colorOnSurfaceVariant"/>

                    <EditText
                        android:id="@+id/etPromoCode"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Enter promo code"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:singleLine="true"/>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyPromo"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="Apply"
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/poppins_semibold"
                    app:backgroundTint="@color/MainColor"
                    app:cornerRadius="12dp"/>

            </LinearLayout>

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="4dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- ── Order Summary Card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_info_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order Summary"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="12dp"/>

                <!-- Subtotal Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Subtotal"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/tvSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$1,099.98"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/poppins_medium"/>
                </LinearLayout>

                <!-- Shipping Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Shipping"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/tvShipping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Free"
                        android:textSize="13sp"
                        android:textColor="#1B7B3A"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>

                <!-- Discount Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Discount"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/poppins_regular"/>

                    <TextView
                        android:id="@+id/tvDiscountAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="- $0.00"
                        android:textSize="13sp"
                        android:textColor="#FF4444"
                        android:fontFamily="@font/poppins_semibold"/>
                </LinearLayout>

                <!-- Divider inside card -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant"
                    android:layout_marginBottom="14dp"/>

                <!-- Total Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textSize="15sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/poppins_semibold"/>

                    <TextView
                        android:id="@+id/tvTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0000"
                        android:textSize="20sp"
                        android:textColor="@color/MainColor"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ─────────────────────────────────────────
         Empty Cart State (GONE by default)
    ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutEmptyCart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_cart"
            android:alpha="0.25"
            app:tint="?attr/colorOnSurfaceVariant"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Your cart is empty"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/poppins_semibold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Add items to start shopping"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="@font/poppins_regular"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShopNow"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="32dp"
            android:text="Shop Now"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/poppins_semibold"
            app:backgroundTint="@color/MainColor"
            app:cornerRadius="14dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:background="@drawable/bg_bottom_bar"
        android:gravity="center_vertical">

        <!-- Total Price Summary -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Price"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:fontFamily="@font/poppins_regular"/>

            <TextView
                android:id="@+id/tvBottomTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1,099.98"
                android:textSize="20sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>

        <!-- Checkout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckout"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:paddingHorizontal="28dp"
            android:text="Checkout"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/poppins_semibold"
            app:backgroundTint="@color/MainColor"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textEnd"
            app:iconPadding="8dp"
            app:iconTint="@android:color/white"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>