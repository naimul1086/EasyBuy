<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".Views.OrderFragment">

    <!-- ═══════════════════════════════════════════
         SCROLLABLE CONTENT
    ════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Header ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Orders"
                        android:textSize="22sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:id="@+id/tvOrderCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 orders placed"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:fontFamily="@font/poppins_regular"/>
                </LinearLayout>

                <!-- Filter badge -->
                <TextView
                    android:id="@+id/tvFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All Orders"
                    android:background="@drawable/bg_category_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/MainColor"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:fontFamily="@font/poppins_semibold"/>
            </LinearLayout>

            <!-- ── Filter Chip Row ─────────────────────── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:clipToPadding="false">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:chipSpacingHorizontal="6dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="All"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"
                        app:chipBackgroundColor="@color/MainColor"
                        android:textColor="@android:color/white"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPending"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Pending"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipProcessing"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Processing"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDelivered"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Delivered"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCancelled"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Cancelled"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_medium"
                        style="@style/Widget.Material3.Chip.Filter"/>

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- ── Orders RecyclerView ─────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                tools:itemCount="4"
                tools:listitem="@layout/item_order"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════
         EMPTY STATE
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutEmptyOrders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="gone">

        <!-- Bag icon with decorative ring -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal">

            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_info_card"
                android:layout_gravity="center"/>

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                android:alpha="0.30"
                app:tint="@color/MainColor"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="No orders yet"
            android:textSize="20sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Your completed orders will appear here"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartShopping"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="36dp"
            android:text="Start Shopping"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:fontFamily="@font/poppins_semibold"
            app:backgroundTint="@color/MainColor"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_cart"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@android:color/white"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>