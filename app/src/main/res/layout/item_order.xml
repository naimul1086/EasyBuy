<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/colorSurface"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══ TOP HEADER BAND ════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- Order icon circle -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_info_card">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cart"
                    app:tint="@color/MainColor"/>
            </FrameLayout>

            <!-- Order ID + Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order #XXXXXXXX"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tvOrderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="25 Mar 2026 · 10:45 AM"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:background="@drawable/bg_stock_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textSize="11sp"
                android:textColor="#1B7B3A"
                android:fontFamily="@font/poppins_semibold"/>

        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"/>

        <!-- ══ TIMELINE STATUS TRACKER ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">

            <!-- Step 1: Order Placed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Dot -->
                <FrameLayout
                    android:id="@+id/dotPlaced"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_active">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/bg_circle_white_alpha"
                        app:tint="@android:color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Placed"
                    android:textSize="9sp"
                    android:textColor="@color/MainColor"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Line 1→2 -->
            <View
                android:id="@+id/line1"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.6"
                android:layout_marginBottom="16dp"
                android:background="@color/MainColor"/>

            <!-- Step 2: Processing -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:id="@+id/dotProcessing"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shipping"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Processing"
                    android:textSize="9sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Line 2→3 -->
            <View
                android:id="@+id/line2"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.6"
                android:layout_marginBottom="16dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- Step 3: Shipped -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:id="@+id/dotShipped"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shipping"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Shipped"
                    android:textSize="9sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Line 3→4 -->
            <View
                android:id="@+id/line3"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.6"
                android:layout_marginBottom="16dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- Step 4: Delivered -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:id="@+id/dotDelivered"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/bg_circle_white_alpha"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="Delivered"
                    android:textSize="9sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"/>

        <!-- ══ ITEMS PREVIEW (horizontal scroll of thumbnails) ══════════════ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/llItemThumbnails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

        </HorizontalScrollView>

        <!-- Item count overflow label -->
        <TextView
            android:id="@+id/tvMoreItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="+2 more items"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="@font/poppins_regular"
            android:visibility="gone"/>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="?attr/colorOutlineVariant"/>

        <!-- ══ PRICE SUMMARY + ACTION ROW ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:gravity="center_vertical">

            <!-- Price block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 items"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvOrderTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="$549.99"
                    android:textSize="18sp"
                    android:textColor="@color/MainColor"
                    android:fontFamily="@font/poppins_bold"/>

                <!-- Promo applied chip -->
                <TextView
                    android:id="@+id/tvPromoApplied"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="🏷 SAVE10 applied"
                    android:textSize="10sp"
                    android:textColor="#FF4444"
                    android:fontFamily="@font/poppins_semibold"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Details button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrderDetails"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:paddingHorizontal="20dp"
                android:text="Details"
                android:textSize="12sp"
                android:textColor="@color/MainColor"
                android:fontFamily="@font/poppins_semibold"
                app:backgroundTint="?attr/colorSurface"
                app:strokeColor="@color/MainColor"
                app:strokeWidth="1.5dp"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>