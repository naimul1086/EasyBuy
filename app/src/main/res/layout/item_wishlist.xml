<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Product Image -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <ImageView
                android:id="@+id/ivWishlistImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_heart_outline"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvWishlistCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electronics"
                android:background="@drawable/bg_category_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/MainColor"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:fontFamily="@font/poppins_semibold"/>

            <TextView
                android:id="@+id/tvWishlistTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Product Title"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/poppins_semibold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvWishlistPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="$0.00"
                android:textSize="15sp"
                android:textColor="@color/MainColor"
                android:fontFamily="@font/poppins_bold"/>

        </LinearLayout>

        <!-- Remove button -->
        <ImageButton
            android:id="@+id/btnRemoveWishlist"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_circle_white_alpha"
            android:src="@drawable/ic_heart_filled"
            android:padding="8dp"
            app:tint="#FF4444"
            android:contentDescription="Remove from wishlist"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>